<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>adurlaub</id>
    <name>AD Urlaub</name>
    <summary>Urlaubsplanung für alle AD-Fachgruppen.</summary>
    <description>Plant und genehmigt ganztägige Urlaubszeiträume und stellt sie anderen lokalen Apps read-only bereit.</description>
    <version>0.4.14-rc.1</version>
    <licence>agpl</licence>
    <author>Simon</author>
    <website>https://github.com/Filzmann/ad-suite</website>
    <bugs>https://github.com/Filzmann/nextcloud-adurlaub/issues</bugs>
    <repository type="git">https://github.com/Filzmann/nextcloud-adurlaub</repository>
    <namespace>AdUrlaub</namespace>
    <category>organization</category>
    <dependencies>
        <php min-version="8.3"/>
        <nextcloud min-version="34" max-version="34"/>
        <app>localbase</app>
        <app>orgsuite</app>
    </dependencies>
    <commands><command>OCA\AdUrlaub\Command\SeedDemoCommand</command></commands>
</info>
